---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  date: string;
  excerpt: string;
  slug: string;
}

const { title, date, excerpt, slug } = Astro.props;

const siteUrl = 'https://agnislav.name';
const canonicalUrl = `${siteUrl}/blog/${slug}`;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  datePublished: date,
  author: {
    '@type': 'Person',
    name: 'Agnislav Onufriichuk',
    url: siteUrl,
  },
  description: excerpt,
  url: canonicalUrl,
};
---

<Base
  title={`${title} — Agni`}
  description={excerpt}
  ogType="article"
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <Nav isBlogPost />
  <main id="main-content">
    <article class="blog-post">
      <div class="container">
        <a href="/#blog" class="back-link" aria-label="Back to all posts">&larr; Back to Writing</a>
        <header>
          <time datetime={date} class="post-date">{formattedDate}</time>
          <h1>{title}</h1>
        </header>
        <div class="prose">
          <slot />
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Base>

<style>
  .blog-post {
    padding-top: 120px;
    padding-bottom: 80px;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 80px);
  }

  .back-link {
    display: inline-block;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: 40px;
    transition: color 0.3s;
  }
  .back-link:hover {
    color: var(--fg);
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 12px;
  }

  h1 {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 48px;
  }

  .prose {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--fg);
  }

  .prose :global(h2) {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 400;
    margin-top: 48px;
    margin-bottom: 16px;
  }

  .prose :global(h3) {
    font-family: var(--serif);
    font-size: 1.25rem;
    font-weight: 400;
    margin-top: 36px;
    margin-bottom: 12px;
  }

  .prose :global(p) {
    margin-bottom: 20px;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 20px;
    padding-left: 24px;
  }

  .prose :global(li) {
    margin-bottom: 8px;
  }

  .prose :global(strong) {
    font-weight: 500;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 20px;
    margin: 24px 0;
    font-style: italic;
    color: var(--muted);
  }

  .prose :global(code) {
    background: var(--card-bg);
    border: 1px solid var(--border);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: var(--card-bg);
    border: 1px solid var(--border);
    padding: 20px;
    border-radius: 4px;
    overflow-x: auto;
    margin: 24px 0;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }
</style>
