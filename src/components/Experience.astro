    color: var(--fg);
    font-weight: 400;
    font-style: italic;
    margin-bottom: 12px;
  }

  .exp-content p {
    color: var(--muted);
    font-size: 0.88rem;
    max-width: 540px;
    line-height: 1.65;
  }

  .exp-earlier {
